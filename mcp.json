{
  "slug" : "task-tracker-mcp",
  "name" : "Task Tracker MCP 003",
  "description" : "MCP server for creating, listing, and completing tasks with in-memory storage",
  "category" : "Productivity",
  "transport" : "STREAMABLE_HTTP",
  "serverUrl" : "http://localhost:3500/mcp",
  "requiresAuth" : true,
  "tools" : [ {
    "name" : "create_task",
    "description" : "Creates a new task with title, optional description, and priority. Returns the task ID",
    "inputSchema" : {
      "type" : "object",
      "properties" : {
        "title" : {
          "type" : "string",
          "description" : "Task title (required, max 200 chars)"
        },
        "description" : {
          "type" : "string",
          "description" : "Optional task details"
        },
        "priority" : {
          "type" : "string",
          "enum" : [ "low", "medium", "high" ],
          "default" : "medium"
        }
      },
      "required" : [ "title" ]
    }
  } ]
}